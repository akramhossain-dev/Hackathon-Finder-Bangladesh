# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in real values
# DO NOT commit .env to version control

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (Phase 1 — REQUIRED) ───────────────────────────────────────────
# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hackathon-finder?retryWrites=true&w=majority

# ─── JWT (Phase 2 — REQUIRED) ─────────────────────────────────────────────────
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_cryptographically_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Redis / BullMQ (Phase 1+) ────────────────────────────────────────────────
# Optional in Phase 1. Required in Phase 5+ (reminders, import queue)
# Get from: https://upstash.com
REDIS_URL=redis://:<password>@your-upstash-endpoint:6380
